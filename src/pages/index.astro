---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import PhilosophySection from '../components/PhilosophySection.astro';
import LevelsSection from '../components/LevelsSection.astro';
import FeaturesSection from '../components/FeaturesSection.astro';
import TestimonialsSection from '../components/TestimonialsSection.astro';
import CTASection from '../components/CTASection.astro';
---
<Layout>
  <Header />
  <main>
    <Hero
      heading="You're not stuck. You're repeating.&#10;And that can change."
      subtext="You don't need more insight. You need to stop repeating what's not working."
      ctaText="Book Your Session"
      ctaLink="/work-with-me"
    />
    <PhilosophySection
      subtitle="You've tried everything"
      title="But patterns don't respond to effort alone."
      paragraphs={[
        "You've done the work. You've reflected. You've tried to evolve. You've tried to \"fix\" things. And yet... you keep ending in the same situations. Different job. Same tension. Different people. Same dynamics. Different effort. Same result.",
        "What you're experiencing is not bad luck. And it's not a lack of effort. You're not stuck because you're weak. You're stuck because you're caught in patterns that don't start with you. But you're the one repeating them.",
        "Until you see them clearly, you'll keep living them. Because what you don't see runs the show.",
      ]}
      image="https://images.unsplash.com/photo-1506126613408-eca07ce68773?q=80&w=2099&auto=format&fit=crop"
      imageAlt="Peaceful transformation"
    />
    <LevelsSection />
    <FeaturesSection />
    <TestimonialsSection />
    <CTASection
      heading="Ready to break the pattern?"
      subtext="This work is not for everyone. If you're ready to see what's actually there — even if you don't like it — then yes, this is for you."
      ctaText="Book Your Session"
      ctaLink="/work-with-me"
    />
  </main>
  <Footer />
</Layout>
