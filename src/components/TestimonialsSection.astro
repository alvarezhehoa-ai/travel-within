---
export interface Testimonial {
  quote: string;
  author: string;
  role?: string;
}
export interface Props {
  title?: string;
  subtitle?: string;
  testimonials?: Testimonial[];
}
const { title = 'What people say', subtitle = 'Real transformations from real people.' } = Astro.props;
const testimonials = Astro.props.testimonials || [
  {
    quote: 'After the coaching, I live. And I\'m not going back to survival mode.',
    author: 'Céline',
    role: 'Author, Editor & Badass',
  },
  {
    quote: 'I finally understood why I kept repeating the same patterns — and more importantly, how to stop.',
    author: 'Marie',
    role: 'Entrepreneur',
  },
];
---
<section class="py-32 bg-tw-white">
  <div class="max-w-screen-xl mx-auto px-6 md:px-12">
    <div class="text-center mb-16">
      <h2 class="font-highlight text-4xl md:text-5xl tracking-tight font-medium text-tw-black mb-4">{title}</h2>
      <p class="text-lg text-tw-gray-600 font-light">{subtitle}</p>
    </div>
    <div class="grid md:grid-cols-2 gap-8 lg:gap-12">
      {testimonials.map(t => (
        <div class="bg-tw-gray-100 rounded-[2rem] p-8 md:p-10 flex flex-col">
          <i data-lucide="quote" class="w-8 h-8 stroke-[1] text-tw-green mb-6"></i>
          <p class="font-highlight text-xl md:text-2xl italic font-normal text-tw-black leading-relaxed mb-8 flex-grow">"{t.quote}"</p>
          <div>
            <p class="text-base font-medium text-tw-black">{t.author}</p>
            {t.role && <p class="text-sm text-tw-gray-600 font-light">{t.role}</p>}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
