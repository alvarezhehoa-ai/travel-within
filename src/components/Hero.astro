---
export interface Props {
  heading?: string;
  subtext?: string;
  ctaText?: string;
  ctaLink?: string;
  image?: string;
  imageAlt?: string;
}
const { heading = "You're not stuck. You're repeating.\nAnd that can change.", subtext = "You don't need more insight. You need to stop repeating what's not working.", ctaText = 'Book Your Session', ctaLink = '#contact', image = '/images/hero.jpg', imageAlt = 'Transformational coaching' } = Astro.props;
---
<section class="relative min-h-screen pt-32 lg:pt-40 pb-0 overflow-hidden flex flex-col justify-between bg-tw-gray-100">
  <div class="max-w-screen-2xl mx-auto px-6 md:px-12 w-full grid lg:grid-cols-12 gap-12 lg:gap-0 relative z-10 flex-grow">
    <div class="lg:col-span-5 flex flex-col justify-center relative z-20 pb-20 lg:pb-24 mt-12 lg:mt-0">
      <h1 class="font-highlight text-3xl md:text-4xl lg:text-[2.75rem] leading-[1.08] tracking-tighter font-medium text-tw-black mb-8">
        {heading.split('\n').map((line, i) => <>{i > 0 && <br />}{line}</>)}
      </h1>
      <div class="pl-6 border-l-[1.5px] border-tw-gray-200 mb-12">
        <p class="text-lg md:text-xl text-tw-gray-600 font-light leading-relaxed max-w-md">
          {subtext}
        </p>
      </div>
      <div>
        <a href={ctaLink} class="inline-flex bg-tw-yellow text-tw-black px-8 py-5 rounded-full items-center gap-3 hover:bg-tw-yellow/80 transition-colors group font-medium">
          <span class="text-base tracking-wide uppercase">{ctaText}</span>
          <i data-lucide="arrow-right" class="w-5 h-5 stroke-[1.5] group-hover:translate-x-1 transition-transform"></i>
        </a>
      </div>
    </div>
    <div class="lg:col-span-7 relative min-h-[280px] lg:min-h-full w-full lg:h-[45vh]">
      <div class="absolute top-[5%] lg:top-[8%] right-[0%] lg:right-[5%] w-[88%] lg:w-[72%] aspect-square rounded-full overflow-hidden z-0">
        <img src={image} alt={imageAlt} class="w-full h-full object-cover object-[60%_30%]" />
        <div class="absolute inset-0 bg-black/5 mix-blend-overlay"></div>
      </div>
    </div>
  </div>
</section>
