---
export interface Level {
  title: string;
  subtitle: string;
  description?: string;
  image: string;
  tag: string;
  link: string;
}
export interface Props {
  title?: string;
  subtitle?: string;
  levels?: Level[];
}
const { title = 'Break the pattern at 3 levels', subtitle = 'The work meets you wherever the pattern shows up.' } = Astro.props;
const levels = Astro.props.levels || [
  {
    title: 'Individual',
    subtitle: 'Where it lives in your body and daily life',
    description: 'Emotional loops, addictive patterns, internal imbalance, body-held stress, self-sabotage. You don\'t need more self-discipline. You need to understand what your body has been trying to solve.',
    image: '/images/blur-stuck.jpg',
    tag: 'Body & Mind',
    link: '/work-with-me',
  },
  {
    title: 'Relationships',
    subtitle: 'Where it repeats in your family and connections',
    description: 'Family patterns, invisible loyalties, relational dynamics, belonging and exclusion, inherited roles. What repeats in our relationships rarely starts with us.',
    image: '/images/eloaportrait.jpg',
    tag: 'Family & System',
    link: '/work-with-me',
  },
  {
    title: 'Organizations',
    subtitle: 'Where it plays out in teams and leadership',
    description: 'Recurring team dynamics, leadership blind spots, systemic misalignment, change that doesn\'t stick. Most organizational problems are not strategic failures — they are systemic patterns.',
    image: '/images/freedom.png',
    tag: 'Work & System',
    link: '/work-with-me',
  },
];
---
<section class="py-32 bg-tw-gray-100 overflow-hidden">
  <div class="max-w-screen-2xl mx-auto px-6 md:px-12 mb-16">
    <div>
      <h2 class="font-highlight text-[32px] md:text-[44px] tracking-tight font-medium text-tw-black mb-4">{title}</h2>
      <p class="text-lg text-tw-gray-600 max-w-xl font-light">{subtitle}</p>
    </div>
  </div>
  <div class="max-w-screen-2xl mx-auto px-6 md:px-12 grid md:grid-cols-3 gap-6 pb-12">
    {levels.map(level => (
      <div class="bg-white rounded-[2rem] p-4 group cursor-pointer hover:shadow-xl transition-shadow duration-300">
        <div class="relative w-full aspect-[4/3] rounded-[1.5rem] overflow-hidden mb-6">
          <img src={level.image} alt={level.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
          <div class="absolute top-4 left-4 bg-white/90 backdrop-blur-sm px-3 py-1 rounded-full text-xs font-medium uppercase tracking-widest text-tw-black">{level.tag}</div>
        </div>
        <div class="px-2 pb-4">
          <h3 class="text-2xl tracking-tight font-medium text-tw-black mb-1">{level.title}</h3>
          <p class="text-sm text-tw-gray-600 uppercase tracking-widest mb-3 font-light">{level.subtitle}</p>
          <a href={level.link} class="flex items-center text-tw-green font-medium text-sm group-hover:gap-2 transition-all mt-6">
            Explore {level.title} Work <i data-lucide="arrow-right" class="w-4 h-4 stroke-[1.5] ml-1"></i>
          </a>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>
