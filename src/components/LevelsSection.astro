---
export interface Level {
  title: string;
  subtitle: string;
  description: string;
  image: string;
  tag: string;
  link: string;
}
export interface Props {
  title?: string;
  subtitle?: string;
  levels?: Level[];
}
const { title = 'Break the pattern at 3 levels', subtitle = 'The work meets you wherever the pattern shows up.' } = Astro.props;
const levels = Astro.props.levels || [
  {
    title: 'Individual',
    subtitle: 'Where it lives in your body and daily life',
    description: 'Emotional loops, addictive patterns, internal imbalance, body-held stress, self-sabotage. You don\'t need more self-discipline. You need to understand what your body has been trying to solve.',
    image: '/images/blur-stuck.jpg',
    tag: 'Body & Mind',
    link: '/work-with-me',
  },
  {
    title: 'Relationships',
    subtitle: 'Where it repeats in your family and connections',
    description: 'Family patterns, invisible loyalties, relational dynamics, belonging and exclusion, inherited roles. What repeats in our relationships rarely starts with us.',
    image: '/images/eloaportrait.jpg',
    tag: 'Family & System',
    link: '/work-with-me',
  },
  {
    title: 'Organizations',
    subtitle: 'Where it plays out in teams and leadership',
    description: 'Recurring team dynamics, leadership blind spots, systemic misalignment, change that doesn\'t stick. Most organizational problems are not strategic failures — they are systemic patterns.',
    image: '/images/freedom.png',
    tag: 'Work & System',
    link: '/work-with-me',
  },
];
---
<section class="py-32 bg-tw-gray-100 overflow-hidden">
  <div class="max-w-screen-2xl mx-auto px-6 md:px-12 mb-16 flex flex-col md:flex-row md:items-end justify-between gap-8">
    <div>
      <h2 class="font-highlight text-4xl md:text-5xl tracking-tight font-medium text-tw-black mb-4">{title}</h2>
      <p class="text-lg text-tw-gray-600 max-w-xl font-light">{subtitle}</p>
    </div>
    <div class="flex gap-4">
      <button class="w-12 h-12 rounded-full border border-tw-gray-200 flex items-center justify-center hover:bg-white transition-colors" aria-label="Previous" id="levels-prev">
        <i data-lucide="arrow-left" class="w-5 h-5 stroke-[1.5] text-tw-black"></i>
      </button>
      <button class="w-12 h-12 rounded-full border border-tw-gray-200 flex items-center justify-center hover:bg-white transition-colors" aria-label="Next" id="levels-next">
        <i data-lucide="arrow-right" class="w-5 h-5 stroke-[1.5] text-tw-black"></i>
      </button>
    </div>
  </div>
  <div class="flex gap-6 px-6 md:px-12 overflow-x-auto no-scrollbar snap-x snap-mandatory pb-12" id="levels-scroll">
    {levels.map(level => (
      <div class="min-w-[320px] md:min-w-[400px] bg-white rounded-[2rem] p-4 snap-start group cursor-pointer hover:shadow-xl transition-shadow duration-300">
        <div class="relative w-full aspect-[4/3] rounded-[1.5rem] overflow-hidden mb-6">
          <img src={level.image} alt={level.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
          <div class="absolute top-4 left-4 bg-white/90 backdrop-blur-sm px-3 py-1 rounded-full text-xs font-medium uppercase tracking-widest text-tw-black">{level.tag}</div>
        </div>
        <div class="px-2 pb-4">
          <h3 class="text-2xl tracking-tight font-medium text-tw-black mb-1">{level.title}</h3>
          <p class="text-sm text-tw-gray-600 uppercase tracking-widest mb-3 font-light">{level.subtitle}</p>
          <p class="text-base text-tw-gray-600 mb-6 line-clamp-2 font-light">{level.description}</p>
          <a href={level.link} class="flex items-center text-tw-green font-medium text-sm group-hover:gap-2 transition-all">
            Explore {level.title} Work <i data-lucide="arrow-right" class="w-4 h-4 stroke-[1.5] ml-1"></i>
          </a>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<script>
  const scroll = document.getElementById('levels-scroll');
  const prev = document.getElementById('levels-prev');
  const next = document.getElementById('levels-next');
  if (scroll && prev && next) {
    prev.addEventListener('click', () => { scroll.scrollBy({ left: -400, behavior: 'smooth' }); });
    next.addEventListener('click', () => { scroll.scrollBy({ left: 400, behavior: 'smooth' }); });
  }
</script>
