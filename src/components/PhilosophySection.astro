---
export interface Props {
  title?: string;
  subtitle?: string;
  paragraphs?: string[];
  image?: string;
  imageAlt?: string;
  linkText?: string;
  linkHref?: string;
}
const { title = "Rooted in awareness, designed for real change.", subtitle = 'Our Philosophy', paragraphs = ['You\'ve done the work. You\'ve reflected. You\'ve tried to evolve. You\'ve tried to "fix" things. And yet... you keep ending in the same situations. Different job. Same tension. Different people. Same dynamics. Different effort. Same result.', "What you're experiencing is not bad luck. And it's not a lack of effort. You're not stuck because you're weak. You're stuck because you're caught in patterns that don't start with you. But you're the one repeating them. Until you see them clearly, you'll keep living them. Because what you don't see runs the show."], image = '/images/home-pattern.jpg', imageAlt = 'Break the pattern', linkText = 'Explore my approach', linkHref = '/work-with-me' } = Astro.props;
---
<section class="py-32 bg-tw-white relative">
  <div class="max-w-screen-2xl mx-auto px-6 md:px-12 grid lg:grid-cols-2 gap-16 lg:gap-24 items-center">
    <div class="relative">
      <img src={image} alt={imageAlt} class="w-[85%] aspect-[4/5] object-cover rounded-3xl" loading="lazy" />
    </div>
    <div class="flex flex-col space-y-8">
      <div class="inline-flex items-center gap-3">
        <span class="w-8 h-[1px] bg-tw-green"></span>
        <span class="text-[20px] md:text-[26px] font-medium tracking-wide uppercase text-tw-green">{subtitle}</span>
      </div>
      <h2 class="font-highlight text-[18px] md:text-[24px] lg:text-[30px] tracking-tight font-medium text-tw-black leading-[1.15]">
        {title}
      </h2>
      {paragraphs.map(p => (
        <p class="text-lg text-tw-gray-600 font-light leading-relaxed" set:html={p} />
      ))}
      <div class="pt-4">
        <a href={linkHref} class="inline-flex items-center gap-2 text-tw-black border-b border-tw-black pb-1 hover:text-tw-green hover:border-tw-green transition-colors group">
          <span class="text-base font-medium">{linkText}</span>
          <i data-lucide="arrow-right" class="w-4 h-4 stroke-[1.5] group-hover:translate-x-1 transition-transform"></i>
        </a>
      </div>
    </div>
  </div>
</section>
