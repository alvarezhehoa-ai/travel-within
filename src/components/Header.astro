---
const links = [
  { href: '/', label: 'Home' },
  { href: '/work-with-me', label: 'Work With Me' },
  { href: '/about', label: 'About' },
];
---
<nav class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-white/80 backdrop-blur-md border-b border-transparent" id="navbar">
  <div class="max-w-screen-2xl mx-auto px-6 md:px-12 h-24 flex items-center justify-between">
    <a href="/" class="flex items-center gap-3 z-50">
      <img src="/images/logo.png" alt="Travel Within" class="w-8 h-8 object-contain" />
      <div class="flex flex-col">
        <span class="text-base font-medium tracking-widest uppercase leading-none text-tw-black">Travel Within</span>
        <span class="text-[10px] tracking-widest text-tw-gray-600 uppercase mt-1">Break the patterns</span>
      </div>
    </a>
    <div class="hidden lg:flex items-center gap-10">
      {links.map(link => (
        <a href={link.href} class="text-base text-tw-black hover:text-tw-green transition-colors font-normal tracking-wide uppercase">{link.label}</a>
      ))}
    </div>
    <a href="#contact" class="hidden md:flex fixed top-0 right-0 bg-tw-yellow text-tw-black px-10 py-6 rounded-bl-[40px] items-center gap-3 z-50 hover:bg-tw-yellow/80 transition-colors group">
      <span class="text-base font-normal tracking-wide font-medium">Book Your Session</span>
      <i data-lucide="arrow-right" class="w-5 h-5 stroke-[1.5] group-hover:translate-x-1 transition-transform"></i>
    </a>
    <button class="lg:hidden z-50 p-2" id="mobile-menu-btn" aria-label="Toggle Menu">
      <i data-lucide="menu" class="w-6 h-6 stroke-[1.5]"></i>
    </button>
  </div>
  <div id="mobile-menu" class="fixed inset-0 bg-white z-40 flex flex-col justify-center items-center gap-8 opacity-0 pointer-events-none transition-opacity duration-300">
    {links.map(link => (
      <a href={link.href} class="text-3xl font-medium tracking-tight text-tw-black mobile-link">{link.label}</a>
    ))}
    <a href="#contact" class="mt-4 bg-tw-yellow text-tw-black px-8 py-4 rounded-full text-lg font-normal tracking-wide font-medium mobile-link">Book Your Session</a>
  </div>
</nav>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileLinks = document.querySelectorAll('.mobile-link');
  let isMenuOpen = false;

  function toggleMenu() {
    isMenuOpen = !isMenuOpen;
    if (isMenuOpen) {
      mobileMenu.classList.remove('opacity-0', 'pointer-events-none');
      mobileMenu.classList.add('opacity-100', 'pointer-events-auto');
      menuBtn.innerHTML = '<i data-lucide="x" class="w-6 h-6 stroke-[1.5]"></i>';
      document.body.style.overflow = 'hidden';
    } else {
      mobileMenu.classList.add('opacity-0', 'pointer-events-none');
      mobileMenu.classList.remove('opacity-100', 'pointer-events-auto');
      menuBtn.innerHTML = '<i data-lucide="menu" class="w-6 h-6 stroke-[1.5]"></i>';
      document.body.style.overflow = 'auto';
    }
    lucide.createIcons();
  }

  menuBtn.addEventListener('click', toggleMenu);
  mobileLinks.forEach(link => link.addEventListener('click', toggleMenu));

  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      navbar.classList.add('shadow-sm');
      navbar.style.borderColor = '#E8E8E0';
    } else {
      navbar.classList.remove('shadow-sm');
      navbar.style.borderColor = 'transparent';
    }
  });
</script>
