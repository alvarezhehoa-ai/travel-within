---
export interface Feature {
  icon: string;
  title: string;
  description: string;
}
export interface Props {
  features?: Feature[];
  bgGreen?: boolean;
}
const features = Astro.props.features || [
  {
    icon: 'heart',
    title: 'Your Body',
    description: 'Where tension, stress, and imbalance accumulate. Your patterns live in your nervous system — effort alone can\'t touch them. We work at the source, not the symptom.',
  },
  {
    icon: 'users',
    title: 'Your Family',
    description: 'Where patterns start, sometimes long before you. Invisible loyalties, inherited roles, dynamics that recreate themselves until you see them clearly.',
  },
  {
    icon: 'building',
    title: 'Your Work',
    description: 'Where these patterns play out again and again in teams, leadership, and organizational culture. The problem is not just strategy — it\'s what no one can see from the inside.',
  },
];
const bgGreen = Astro.props.bgGreen ?? true;
const sectionBg = bgGreen ? 'bg-tw-green text-white' : 'bg-tw-gray-100 text-tw-black';
const textMuted = bgGreen ? 'text-white/80' : 'text-tw-gray-600';
const iconColor = bgGreen ? 'text-tw-yellow' : 'text-tw-green';
---
<section class={`py-24 ${sectionBg}`}>
  <div class="max-w-screen-xl mx-auto px-6 md:px-12 grid md:grid-cols-3 gap-12 lg:gap-20">
    {features.map(f => (
      <div class="flex flex-col items-center text-center">
        <i data-lucide={f.icon} class={`w-8 h-8 stroke-[1.5] mb-6 ${iconColor}`}></i>
        <h3 class="text-2xl tracking-tight font-medium mb-3">{f.title}</h3>
        <p class={`text-base font-light leading-relaxed ${textMuted}`}>{f.description}</p>
      </div>
    ))}
  </div>
</section>
